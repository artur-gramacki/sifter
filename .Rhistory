data_artefact <- read.csv(file = file_toy_artefacts, dec = ".", sep = "\t", header = T, stringsAsFactors = T)
sifter_toolbox(
data_main = data,
data_art = data_artefact[2,],
class_col = 5,
internal_number_col = 6,
num_of_classes = 2,
save_2D = TRUE
)
