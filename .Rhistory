file_toy <- system.file("extdata", "toy_example.csv", package = "sifter")
file_toy_artefacts <- system.file("extdata", "toy_example_artefacts.csv", package = "sifter")
sifter_toolbox(
data_main = data,
data_art = data_artefact[2,],
class_col = 5,
internal_number_col = 6,
num_of_classes = 2,
save_2D = TRUE
)
file_toy <- system.file("extdata", "toy_example.csv", package = "sifter")
file_toy_artefacts <- system.file("extdata", "toy_example_artefacts.csv", package = "sifter")
