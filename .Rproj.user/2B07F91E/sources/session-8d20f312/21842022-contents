#######################################################################
par(mfrow = c(2,2), pty = "m")
par(mai = c(0.1, 0, 0, 0))

# -------
# Step 1
#--------
# The first dendrogram is generated. The class where the artefact
# observation is located is surrounded by a blue rectangle
out <- sifter(
  data_main = data,
  data_art = data_artefact[2,],
  class_col = class_col ,
  num_of_classes = 2,
  internal_number_col = internal_number_col ,
  mai_bottom = 0.8,
  verbose = TRUE)

out$is_homogenous

# -------
# Step 2
# -------
# Now, the data from the blue rectangle from Step 1 become inputs
# to the sifter() function. And again, The class where the artefact
# observation is located is surrounded by a blue rectangle.
# The artefact Observation is still in a heterogeneous class, so another
# step is required,
r <- which(rownames(out$data_with_artefact) == out$artefact_row)
data_2 <- out$data_with_artefact[-r, ]
data_artefact_2 <- out$data_with_artefact[r, ]
out <- sifter(
  data_main = data_2,
  data_art = data_artefact_2,
  class_col = class_col ,
  internal_number_col = internal_number_col ,
  num_of_classes = 2,
  mai_bottom = 0.8,
  verbose = TRUE)

out$is_homogenous

# -------
# Step 3
# -------
# After completing the next step, the artefact observation is still in a
# heterogeneous class, so another step is required.
r <- which(rownames(out$data_with_artefact) == out$artefact_row)
data_2 <- out$data_with_artefact[-r, ]
data_artefact_2 <- out$data_with_artefact[r, ]
out <- sifter(
  data_main = data_2,
  data_art = data_artefact_2,
  class_col = class_col ,
  internal_number_col = internal_number_col ,
  num_of_classes = 2,
  mai_bottom = 0.8,
  verbose = TRUE)

out$is_homogenous

# -------
# Step 4
# -------
# The fourth step ends up in a homogenous class which ends the analysis.
r <- which(rownames(out$data_with_artefact) == out$artefact_row)
data_2 <- out$data_with_artefact[-r, ]
data_artefact_2 <- out$data_with_artefact[r, ]
out <- sifter(
  data_main = data_2,
  data_art = data_artefact_2,
  class_col = class_col ,
  internal_number_col = internal_number_col ,
  num_of_classes = 2,
  mai_bottom = 0.8,
  verbose = TRUE)

out$is_homogenous

# All the above steps can be enclosed inside an another function (`sifter_toolbox()`)
# and the 4 above steps can now be run subsequently. As a result, 4 `jpeg` files are
# created in the `figs_sifter` directory. In addition, a text file is created where
# detailed results from every step are saved.
sifter_toolbox(
  data_main = data,
  data_art = data_artefact[2,],
  class_col = class_col ,
  internal_number_col = internal_number_col ,
  num_of_classes = 2,
  save_2D = F
)


